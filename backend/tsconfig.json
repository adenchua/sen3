{
  "compilerOptions": {
    "target": "ES6",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node10",
    "module": "CommonJS"
  },
  "include": ["src/**/*.ts"]
}
